{
  "name": "orbit-scientific-calculator",
  "version": "1.0.0",
  "private": true,
  "description": "Orbit Scientific Calculator packaged for web, Android, and iOS via Capacitor.",
  "scripts": {
    "build": "build-web.cmd",
    "cap:init": "npx cap init OrbitScientific com.orbit.scientific",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:copy": "npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "android:refresh": "build-web.cmd && npx cap sync android"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "@capacitor/ios": "^7.6.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.1"
  }
}
